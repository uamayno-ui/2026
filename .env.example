# ── Required for real production: Database (server secret) ─────────────
# Required before enabling auth, orders, payments, monitoring, or cabinet API.
# Never expose DATABASE_URL client-side.
DATABASE_URL=postgresql://FAKE_USER:FAKE_PASSWORD@localhost:5432/FAKE_DATABASE

# ── Feature-gated / future: Redis (server secret, Sprint 4) ────────────
REDIS_URL=redis://localhost:6379/0

# ── Required when Bank ID login is enabled (server secrets) ────────────
# Тестовий контур: https://testid.bank.gov.ua
# Production:      https://id.bank.gov.ua
# Production must set all BANKID_* values. Missing values disable Bank ID safely.
BANKID_ENV=test                  # "test" | "production"
BANKID_CLIENT_ID=
BANKID_CLIENT_SECRET=
BANKID_REDIRECT_URI=http://localhost:3000/api/auth/bankid/callback

# ── Feature-gated / future: Дія.Підпис (server secrets, Sprint 4) ──────
DIIA_SIGN_CLIENT_ID=
DIIA_SIGN_CLIENT_SECRET=

# ── Required when official ДЗК excerpts are enabled (server secrets) ───
# Use only after API access and contract are approved.
DZK_CLIENT_ID=
DZK_CLIENT_SECRET=

# ── Required when ДРРП / monitoring is enabled (server secret) ─────────
# Лише після підписання NDA і договору!
OPENDATABOT_API_KEY=

# ── Required when payments are enabled (server secrets) ────────────────
# Production fails closed if LIQPAY_PUBLIC_KEY or LIQPAY_PRIVATE_KEY is missing.
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SANDBOX=true              # "true" в dev, "false" в production

# ── Required when email delivery is enabled (server secret) ────────────
# https://resend.com/api-keys
RESEND_API_KEY=FAKE_RESEND_API_KEY
EMAIL_FROM=Mayno <noreply@mayno.ua>

# ── Public env, safe for browser: Mapbox GL ────────────────────────────
# https://account.mapbox.com/access-tokens/
# Обмежте токен доменом mayno.ua в production!
NEXT_PUBLIC_MAPBOX_TOKEN=FAKE_MAPBOX_PUBLIC_TOKEN

# ── Required when AI risk analysis is enabled (server secret) ──────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=FAKE_ANTHROPIC_API_KEY

# ── Required when Web Push is enabled (server secrets) ─────────────────
# Генерація: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=FAKE_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=FAKE_VAPID_PRIVATE_KEY
# Accepted: support@mayno.ua or mailto:support@mayno.ua
VAPID_SUBJECT=mailto:support@mayno.ua

# ── Required when Vercel Cron is enabled (server secret) ───────────────
# Vercel Cron передає цей секрет у Authorization: Bearer <CRON_SECRET>
CRON_SECRET=FAKE_CRON_SECRET

# ── Public env, safe for browser: App URL ──────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
