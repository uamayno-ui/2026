# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/mayno

# ── Redis (cache, queue — Sprint 4) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Bank ID НБУ ────────────────────────────────────────────────────────
# Тестовий контур: https://testid.bank.gov.ua
# Production:      https://id.bank.gov.ua
BANKID_ENV=test                  # "test" | "production"
BANKID_CLIENT_ID=
BANKID_CLIENT_SECRET=
BANKID_REDIRECT_URI=http://localhost:3000/api/auth/bankid/callback

# ── Дія.Підпис (Sprint 4) ──────────────────────────────────────────────
DIIA_SIGN_CLIENT_ID=
DIIA_SIGN_CLIENT_SECRET=

# ── e.land.gov.ua — ДЗК API ───────────────────────────────────────────
DZK_CLIENT_ID=
DZK_CLIENT_SECRET=

# ── Opendatabot — ДРРП reseller (Phase 1) ──────────────────────────────
# Лише після підписання NDA і договору!
OPENDATABOT_API_KEY=

# ── LiqPay ─────────────────────────────────────────────────────────────
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SANDBOX=true              # "true" в dev, "false" в production

# ── Resend — email-нотифікації ─────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=Mayno <noreply@mayno.ua>

# ── Mapbox GL ──────────────────────────────────────────────────────────
# https://account.mapbox.com/access-tokens/
# Обмежте токен доменом mayno.ua в production!
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ── Cron ───────────────────────────────────────────────────────────────
# Vercel Cron передає цей секрет у Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# ── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
